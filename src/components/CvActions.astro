---
import type { LocaleContent, Locale } from "../lib/types";

interface Props {
  locale: Locale;
  content: LocaleContent;
  basePath: string;
}

const { locale, content, basePath } = Astro.props;
const pdfPreviewHref = `${basePath.replace(/\/$/, "")}/${locale}/cv/pdf/`;
const cvHref = `${basePath.replace(/\/$/, "")}/${locale}/cv/`;
const pdfHref = `${basePath.replace(/\/$/, "")}${content.cv.pdfPath}`;
---

<section class="section" id="cv-actions">
  <h2 class="section-title">{content.labels.navCv}</h2>
  <div class="contact-grid">
    <article class="contact-card cv-actions">
      <h3>{content.cv.pdfLabel}</h3>
      <p class="section-copy">Updated {content.cv.updatedAt}</p>
      <div class="cta-row">
        <a class="button" href={pdfPreviewHref}>{content.labels.previewPdf}</a>
        <a class="button-secondary" href={pdfHref}>{content.labels.downloadPdf}</a>
        <a class="button-secondary" href={cvHref}>{content.labels.viewCv}</a>
      </div>
    </article>
  </div>
</section>
