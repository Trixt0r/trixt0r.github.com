---
import LocaleSwitcher from "./LocaleSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import type { LocaleContent, Locale } from "../lib/types";

interface Props {
  locale: Locale;
  content: LocaleContent;
  basePath: string;
}

const { locale, content, basePath } = Astro.props;
const { profile, hero, summary, labels, links } = content;
const rootPath = basePath.replace(/\/$/, "");
const pdfHref = `${rootPath}${content.cv.pdfPath}`;
const navItems = [
  { href: "#about", label: labels.sectionAbout },
  { href: "#history", label: labels.sectionHistory },
  { href: "#projects", label: labels.sectionProjects }
];
const quickLinks = [
  { href: links.linkedin, label: "LinkedIn", icon: "linkedin", external: true },
  { href: links.github, label: "GitHub", icon: "github", external: true },
  { href: `tel:${profile.phone.replace(/\s+/g, "")}`, label: labels.phoneLabel, icon: "call" },
  { href: `mailto:${profile.email}`, label: labels.emailLabel, icon: "mail" },
  { href: pdfHref, label: labels.downloadPdf, icon: "picture_as_pdf" }
];
---

<aside class="home-sidebar">
  <div class="home-sidebar__inner">
    <div class="home-sidebar__controls">
      <LocaleSwitcher locale={locale} basePath={basePath} labels={labels} />
      <ThemeToggle labels={labels} />
    </div>

    <div class="home-sidebar__summary">
      <p class="home-sidebar__eyebrow">{summary.yearsExperienceLabel}</p>
      <h1>{profile.name}</h1>
      <p class="home-sidebar__title">{profile.title}</p>
      <p class="home-sidebar__lead">{hero.headline}</p>
    </div>

    <nav class="home-nav" aria-label="Section navigation">
      {navItems.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
    <ul class="home-quick-links" aria-label={labels.sectionContact}>
      {quickLinks.map((item) => (
        <li>
          <a class="icon-button home-quick-links__icon" href={item.href} target={item.external ? "_blank" : undefined} rel={item.external ? "noreferrer" : undefined} aria-label={item.label} title={item.label}>
            {item.icon === "linkedin" ? (
              <svg class="brand-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M19 3A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5A2 2 0 0 1 5 3H19M8.34 17V10.67H6.26V17H8.34M7.3 9.8A1.21 1.21 0 1 0 7.3 7.38A1.21 1.21 0 0 0 7.3 9.8M17.74 17V13.54C17.74 11.69 16.75 10.44 14.84 10.44C13.92 10.44 13.3 10.95 13.05 11.43V10.67H10.97C11 11.17 10.97 17 10.97 17H13.05V13.46C13.05 13.27 13.06 13.08 13.12 12.94C13.27 12.56 13.61 12.17 14.19 12.17C14.94 12.17 15.24 12.74 15.24 13.58V17H17.74Z" fill="currentColor"></path>
              </svg>
            ) : item.icon === "github" ? (
              <svg class="brand-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.59 2 12.25C2 16.78 4.87 20.62 8.84 21.98C9.34 22.08 9.5 21.76 9.5 21.49V19.8C6.73 20.42 6.14 18.59 6.14 18.59C5.68 17.39 5.03 17.07 5.03 17.07C4.12 16.43 5.1 16.44 5.1 16.44C6.1 16.51 6.63 17.5 6.63 17.5C7.52 19.06 8.97 18.61 9.54 18.35C9.63 17.69 9.89 17.24 10.18 16.98C7.97 16.72 5.65 15.84 5.65 11.93C5.65 10.81 6.04 9.89 6.68 9.17C6.58 8.91 6.24 7.87 6.78 6.47C6.78 6.47 7.62 6.19 9.53 7.53C10.33 7.3 11.18 7.19 12.03 7.19C12.88 7.19 13.73 7.3 14.53 7.53C16.44 6.19 17.28 6.47 17.28 6.47C17.82 7.87 17.48 8.91 17.38 9.17C18.02 9.89 18.41 10.81 18.41 11.93C18.41 15.85 16.08 16.72 13.86 16.97C14.22 17.29 14.54 17.91 14.54 18.87V21.49C14.54 21.76 14.7 22.09 15.21 21.98C19.18 20.62 22.05 16.78 22.05 12.25C22.05 6.59 17.57 2 12 2Z" fill="currentColor"></path>
              </svg>
            ) : (
              <span class="material-symbols-outlined" aria-hidden="true">{item.icon}</span>
            )}
          </a>
        </li>
      ))}
    </ul>
  </div>
</aside>
