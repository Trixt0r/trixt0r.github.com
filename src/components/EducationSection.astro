---
import type { LocaleContent } from "../lib/types";

interface Props {
  content: LocaleContent;
}

const { content } = Astro.props;
---

<section class="section" id="education">
  <h2 class="section-title">{content.labels.sectionEducation}</h2>
  <div class="info-grid">
    {content.education.items.map((item) => (
      <article class="info-card">
        <h3>{item.degree}</h3>
        <div class="card-meta">{item.institution} · {item.period}</div>
        <p class="section-copy">{item.summary}</p>
      </article>
    ))}
  </div>
</section>
