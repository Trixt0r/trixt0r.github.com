---
import type { LocaleContent, Locale } from "../lib/types";

interface Props {
  locale: Locale;
  content: LocaleContent;
  basePath: string;
}

const { locale, content, basePath } = Astro.props;
const { hero, profile, summary, labels, links } = content;
const cvHref = `${basePath.replace(/\/$/, "")}/${locale}/cv/`;
const mailHref = `mailto:${profile.email}`;
---

<section class="hero section">
  <div class="hero__copy">
    <div class="eyebrow">{summary.yearsExperienceLabel}</div>
    <h1>{hero.headline}</h1>
    <p class="section-copy">{hero.subheadline}</p>
    <div class="cta-row">
      <a class="button" href={cvHref}>{hero.primaryCtaLabel}</a>
      <a class="button-secondary" href={mailHref}>{hero.secondaryCtaLabel}</a>
      <a class="button-secondary" href={links.github} target="_blank" rel="noreferrer">GitHub</a>
      <a class="button-secondary" href={links.linkedin} target="_blank" rel="noreferrer">LinkedIn</a>
    </div>
  </div>
  <aside class="hero__aside">
    <h2>{profile.title}</h2>
    <ul class="detail-list">
      <li class="pill"><strong>{labels.locationLabel}:</strong>&nbsp;{profile.location}</li>
      <li class="pill"><strong>{labels.emailLabel}:</strong>&nbsp;{profile.email}</li>
      <li class="pill"><strong>{labels.phoneLabel}:</strong>&nbsp;{profile.phone}</li>
    </ul>
    <p class="section-copy">{summary.blurb}</p>
  </aside>
</section>
