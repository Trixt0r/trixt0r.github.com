---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/components.css";

import type { LocaleContent, Locale } from "../lib/types";

interface Props {
  locale: Locale;
  content: LocaleContent;
  pageTitle?: string;
}

const { locale, content, pageTitle } = Astro.props;
const title = pageTitle ? `${pageTitle} | ${content.profile.name}` : content.seo.title;
const description = content.seo.description;
const baseUrl = import.meta.env.SITE;
const assetPath = (path: string) => `${import.meta.env.BASE_URL}${path}`;
const pathname = Astro.url.pathname;
const canonical = new URL(pathname, baseUrl).toString();
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f3f4f8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b1020" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={assetPath("favicon.svg")} type="image/svg+xml" />
    <link rel="alternate icon" href={assetPath("favicon.ico")} sizes="any" />
    <link rel="apple-touch-icon" href={assetPath("apple-touch-icon.png")} />
    <link rel="manifest" href={assetPath("site.webmanifest")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0" />
    <script is:inline>
      const storedTheme = localStorage.getItem("preferred-theme");
      if (storedTheme && storedTheme !== "system") {
        document.documentElement.setAttribute("data-theme", storedTheme);
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
