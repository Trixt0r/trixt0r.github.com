---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/components.css";

import type { LocaleContent, Locale } from "../lib/types";
import { buildPath, locales } from "../lib/i18n";

interface Props {
  locale: Locale;
  content: LocaleContent;
  pageTitle?: string;
  pathSuffix?: string;
  noindex?: boolean;
}

const { locale, content, pageTitle, pathSuffix = "/", noindex = false } = Astro.props;
const title = pageTitle ? `${pageTitle} | ${content.profile.name}` : content.seo.title;
const description = content.seo.description;
const baseUrl = import.meta.env.SITE;
const assetPath = (path: string) => `${import.meta.env.BASE_URL}${path}`;
const siteName = `${content.profile.name} Portfolio`;
const keywords = content.seo.keywords?.join(", ");
const localeCodes: Record<Locale, string> = {
  de: "de_CH",
  en: "en_US",
  ru: "ru_RU"
};
const alternateLinks = locales.map((currentLocale) => ({
  locale: currentLocale,
  href: new URL(buildPath(import.meta.env.BASE_URL, currentLocale, pathSuffix), baseUrl).toString()
}));
const canonical = alternateLinks.find((entry) => entry.locale === locale)?.href ?? new URL(Astro.url.pathname, baseUrl).toString();
const socialImage = new URL(assetPath("favicon-512.png"), baseUrl).toString();
const profileUrl = new URL(buildPath(import.meta.env.BASE_URL, locale), baseUrl).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: content.profile.name,
  jobTitle: content.profile.title,
  description,
  url: profileUrl,
  image: socialImage,
  email: `mailto:${content.profile.email}`,
  telephone: content.profile.phone,
  address: {
    "@type": "PostalAddress",
    addressLocality: content.profile.location,
    addressCountry: "CH"
  },
  sameAs: [content.links.github, content.links.linkedin],
  knowsLanguage: content.languages.items.map((item) => item.name)
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={content.profile.name} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="theme-color" content="#f3f4f8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0b1020" media="(prefers-color-scheme: dark)" />
    <link rel="canonical" href={canonical} />
    {alternateLinks.map((entry) => (
      <link rel="alternate" hreflang={entry.locale} href={entry.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(buildPath(import.meta.env.BASE_URL, "de", pathSuffix), baseUrl).toString()} />
    <link rel="icon" href={assetPath("favicon.svg")} type="image/svg+xml" />
    <link rel="alternate icon" href={assetPath("favicon.ico")} sizes="any" />
    <link rel="apple-touch-icon" href={assetPath("apple-touch-icon.png")} />
    <link rel="manifest" href={assetPath("site.webmanifest")} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:locale" content={localeCodes[locale]} />
    {alternateLinks.filter((entry) => entry.locale !== locale).map((entry) => (
      <meta property="og:locale:alternate" content={localeCodes[entry.locale]} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,500,0,0" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <script is:inline>
      const storedTheme = localStorage.getItem("preferred-theme");
      if (storedTheme && storedTheme !== "system") {
        document.documentElement.setAttribute("data-theme", storedTheme);
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
