---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import { getContent } from "../../../lib/content";
import { locales, formatPeriod } from "../../../lib/i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as "de" | "en" | "ru";
const content = getContent(locale);
const basePath = import.meta.env.BASE_URL;
const pdfPreviewHref = `${basePath.replace(/\/$/, "")}/${locale}/cv/pdf/`;
const pdfHref = `${basePath.replace(/\/$/, "")}${content.cv.pdfPath}`;
---

<BaseLayout locale={locale} content={content} pageTitle={content.labels.navCv}>
  <div class="page-shell">
    <Header locale={locale} content={content} pathSuffix="/cv/" basePath={basePath} />
    <main class="container cv-page">
      <section class="cv-header">
        <div class="eyebrow">{content.profile.location}</div>
        <h1>{content.profile.name}</h1>
        <p>{content.hero.subheadline}</p>
        <div class="cta-row">
          <a class="button" href={pdfPreviewHref}>{content.labels.previewPdf}</a>
          <a class="button-secondary" href={pdfHref}>{content.labels.downloadPdf}</a>
          <button class="button-secondary" type="button" onclick="window.print()">{content.labels.printCv}</button>
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">{content.labels.sectionSnapshot}</h2>
        <p class="section-copy">{content.summary.blurb}</p>
      </section>

      <section class="section">
        <h2 class="section-title">{content.labels.sectionExperience}</h2>
        <div class="timeline">
          {content.experience.map((item) => (
            <article class="timeline-item">
              <div class="timeline-item__meta">{formatPeriod(item.start, item.end, locale, content.labels.timelineToday)} · {item.location}</div>
              <h3>{item.role} · {item.company}</h3>
              <p class="section-copy">{item.summary}</p>
              <ul>
                {item.highlights.map((detail) => <li>{detail}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">{content.labels.sectionSkills}</h2>
        <div class="skills-grid">
          {content.skills.groups.map((group) => (
            <article class="skill-group">
              <h3>{group.label}</h3>
              <p class="section-copy">{group.items.join(" · ")}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">{content.labels.sectionProjects}</h2>
        <div class="projects-grid">
          {content.projects.map((project) => (
            <article class="project-card">
              <div class="project-meta">{project.period}</div>
              <h3>{project.name}</h3>
              <p class="section-copy">{project.summary}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section">
        <h2 class="section-title">{content.labels.sectionEducation}</h2>
        <div class="info-grid">
          {content.education.items.map((item) => (
            <article class="info-card">
              <h3>{item.degree}</h3>
              <div class="card-meta">{item.institution} · {item.period}</div>
              <p class="section-copy">{item.summary}</p>
            </article>
          ))}
        </div>
      </section>
    </main>
    <Footer content={content} />
  </div>
</BaseLayout>
