---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import PdfViewer from "../../../components/PdfViewer.astro";
import Footer from "../../../components/Footer.astro";
import { getContent } from "../../../lib/content";
import { locales } from "../../../lib/i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const locale = Astro.params.lang as "de" | "en" | "ru";
const content = getContent(locale);
const basePath = import.meta.env.BASE_URL;
const pdfHref = `${basePath.replace(/\/$/, "")}${content.cv.pdfPath}`;
const backHref = `${basePath.replace(/\/$/, "")}/${locale}/`;
---

<BaseLayout locale={locale} content={content} pageTitle={content.labels.pdfViewerTitle} pathSuffix="/cv/pdf/" noindex={true}>
  <div class="page-shell">
    <Header locale={locale} content={content} pathSuffix="/cv/pdf/" basePath={basePath} />
    <main class="container">
      <section class="section">
        <div class="pdf-viewer-toolbar">
          <div>
            <h1 class="section-title" style="margin-bottom: 0.3rem;">{content.labels.pdfViewerTitle}</h1>
            <p class="section-copy" style="margin: 0;">{content.labels.pdfViewerHint}</p>
          </div>
          <div class="cta-row">
            <a class="button-secondary" href={backHref}>{content.labels.backToSite}</a>
            <a class="button" href={pdfHref}>{content.labels.downloadPdf}</a>
          </div>
        </div>
        <PdfViewer pdfUrl={pdfHref} />
      </section>
    </main>
    <Footer content={content} />
  </div>
</BaseLayout>
