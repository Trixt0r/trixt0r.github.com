---
import { defaultLocale, locales } from '../lib/i18n';
import { getContent } from '../lib/content';

const basePath = import.meta.env.BASE_URL;
const assetPath = (path: string) => `${basePath}${path}`;
const fallback = `${basePath}${defaultLocale}/`;
const content = getContent(defaultLocale);
const site = import.meta.env.SITE;
const title = content.seo.title;
const description = content.seo.description;
const canonical = new URL(fallback, site).toString();
const socialImage = new URL(assetPath('favicon-512.png'), site).toString();
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{title}</title>
    <meta name='description' content={description} />
    <meta name='author' content={content.profile.name} />
    <meta name='robots' content='noindex, nofollow' />
    <meta name='theme-color' content='#f3f4f8' media='(prefers-color-scheme: light)' />
    <meta name='theme-color' content='#0b1020' media='(prefers-color-scheme: dark)' />
    <link rel='canonical' href={canonical} />
    <link rel='icon' href={assetPath('favicon.svg')} type='image/svg+xml' />
    <link rel='alternate icon' href={assetPath('favicon.ico')} sizes='any' />
    <link rel='apple-touch-icon' href={assetPath('apple-touch-icon.png')} />
    <link rel='manifest' href={assetPath('site.webmanifest')} />
    <meta property='og:type' content='website' />
    <meta property='og:site_name' content='Heinrich Reich Portfolio' />
    <meta property='og:title' content={title} />
    <meta property='og:description' content={description} />
    <meta property='og:url' content={canonical} />
    <meta property='og:image' content={socialImage} />
    <meta property='og:image:secure_url' content={socialImage} />
    <meta property='og:image:type' content='image/png' />
    <meta property='og:image:width' content='512' />
    <meta property='og:image:height' content='512' />
    <meta property='og:image:alt' content='Heinrich Reich portfolio preview' />
    <meta name='twitter:card' content='summary_large_image' />
    <meta name='twitter:title' content={title} />
    <meta name='twitter:description' content={description} />
    <meta name='twitter:image' content={socialImage} />
    <meta name='twitter:image:alt' content='Heinrich Reich portfolio preview' />
    <script is:inline>
      const basePath = {JSON.stringify(basePath)};
      const fallback = {JSON.stringify(defaultLocale)};
      const supportedLocales = {JSON.stringify(locales)};
      const savedLocale = localStorage.getItem('preferred-locale');
      const browserLocales = navigator.languages ?? [navigator.language ?? fallback];
      const candidates = [savedLocale, ...browserLocales].filter(Boolean);

      let nextLocale = fallback;
      for (const value of candidates) {
        const lowered = String(value).toLowerCase();
        const matchedLocale = supportedLocales.find((locale) => lowered.startsWith(locale));
        if (matchedLocale) {
          nextLocale = matchedLocale;
          break;
        }
      }

      window.location.replace(`${basePath}${nextLocale}/`);
    </script>
    <meta http-equiv='refresh' content={`0;url=${fallback}`} />
  </head>
  <body></body>
</html>
