---
import { defaultLocale, locales } from '../lib/i18n';

const basePath = import.meta.env.BASE_URL;
const assetPath = (path: string) => `${basePath}${path}`;
const fallback = `${basePath}${defaultLocale}/`;
---

<!doctype html>
<html lang='en'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <meta name='robots' content='noindex, nofollow' />
    <meta name='theme-color' content='#f3f4f8' media='(prefers-color-scheme: light)' />
    <meta name='theme-color' content='#0b1020' media='(prefers-color-scheme: dark)' />
    <link rel='canonical' href={fallback} />
    <link rel='icon' href={assetPath('favicon.svg')} type='image/svg+xml' />
    <link rel='alternate icon' href={assetPath('favicon.ico')} sizes='any' />
    <link rel='apple-touch-icon' href={assetPath('apple-touch-icon.png')} />
    <link rel='manifest' href={assetPath('site.webmanifest')} />
    <script is:inline>
      const basePath = {JSON.stringify(basePath)};
      const fallback = {JSON.stringify(defaultLocale)};
      const supportedLocales = {JSON.stringify(locales)};
      const savedLocale = localStorage.getItem('preferred-locale');
      const browserLocales = navigator.languages ?? [navigator.language ?? fallback];
      const candidates = [savedLocale, ...browserLocales].filter(Boolean);

      let nextLocale = fallback;
      for (const value of candidates) {
        const lowered = String(value).toLowerCase();
        const matchedLocale = supportedLocales.find((locale) => lowered.startsWith(locale));
        if (matchedLocale) {
          nextLocale = matchedLocale;
          break;
        }
      }

      window.location.replace(`${basePath}${nextLocale}/`);
    </script>
    <meta http-equiv='refresh' content={`0;url=${fallback}`} />
  </head>
  <body></body>
</html>
